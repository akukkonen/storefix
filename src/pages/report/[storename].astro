---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';

const { storename } = Astro.params;
const apiUrl = `https://app.getaccessfix.app/api/report/${storename}`;

interface ReportData {
  shop: string;
  lastScanDate: string;
  score: number;
  totalIssues: number;
  critical: number;
  major: number;
  minor: number;
  pagesScanned: number;
  issuesFixed: number;
}

let report: ReportData | null = null;
let errorType: string | null = null;

try {
  const res = await fetch(apiUrl, { headers: { Accept: 'application/json' } });
  if (res.ok) {
    report = await res.json() as ReportData;
  } else {
    const body = await res.json().catch(() => ({})) as { error?: string };
    errorType = body.error ?? 'unknown';
  }
} catch {
  errorType = 'network';
}

const title = report
  ? `Accessibility Report — ${storename}`
  : 'Accessibility Report';
const description = report
  ? `${storename} scores ${report.score}/100 on automated WCAG 2.2 AA accessibility checks.`
  : 'This accessibility report is not currently available.';

function scoreColor(score: number): string {
  if (score >= 80) return '#16a34a';
  if (score >= 50) return '#ca8a04';
  return '#dc2626';
}

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout title={title} description={description}>
  <div class="report-page">
    {report ? (
      <div class="report-container">
        <header class="report-header">
          <p class="report-label">Accessibility Report</p>
          <h1>{storename}</h1>
          <p class="scan-date">Last scanned {formatDate(report.lastScanDate)}</p>
        </header>

        <div class="score-block">
          <div class="score-number" style={`color: ${scoreColor(report.score)}`}>
            {report.score}
          </div>
          <div class="score-label">out of 100</div>
        </div>

        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-value">{report.pagesScanned}</div>
            <div class="stat-label">Pages scanned</div>
          </div>
          <div class="stat-card">
            <div class="stat-value">{report.totalIssues}</div>
            <div class="stat-label">Issues found</div>
          </div>
          <div class="stat-card">
            <div class="stat-value">{report.issuesFixed}</div>
            <div class="stat-label">Issues fixed</div>
          </div>
        </div>

        <div class="severity-section">
          <h2>Issues by severity</h2>
          <div class="severity-grid">
            <div class="severity-row critical">
              <span class="severity-badge">Critical</span>
              <span class="severity-count">{report.critical}</span>
            </div>
            <div class="severity-row serious">
              <span class="severity-badge">Serious</span>
              <span class="severity-count">{report.major}</span>
            </div>
            <div class="severity-row minor">
              <span class="severity-badge">Minor</span>
              <span class="severity-count">{report.minor}</span>
            </div>
          </div>
        </div>

        <div class="info-section">
          <h2>What this scan covers</h2>
          <p>
            This report is generated by automated WCAG 2.2 AA checks using
            <a href="https://github.com/dequelabs/axe-core" target="_blank" rel="noopener">axe-core</a>,
            the industry-standard accessibility testing engine. The scan checks for issues like
            missing alt text, insufficient color contrast, missing form labels, incorrect heading
            order, and more.
          </p>
        </div>

        <div class="info-section">
          <h2>What requires manual review</h2>
          <p>
            Automated testing catches roughly 30-50% of accessibility issues. The following
            require manual testing and are not covered by this report:
          </p>
          <ul>
            <li>Keyboard navigation and focus management</li>
            <li>Screen reader compatibility</li>
            <li>Meaningful alt text quality (automated checks only detect missing alt text)</li>
            <li>Cognitive accessibility and plain language</li>
            <li>Video captions and audio descriptions</li>
          </ul>
        </div>

        <footer class="report-footer">
          <p>
            Accessibility Monitored by
            <a href="https://getaccessfix.app">AccessFix</a>
          </p>
        </footer>
      </div>
    ) : (
      <div class="report-container">
        <header class="report-header">
          <p class="report-label">Accessibility Report</p>
          <h1>{storename ?? 'Unknown Store'}</h1>
        </header>

        <div class="empty-state">
          {errorType === 'report_disabled' ? (
            <p>This store's accessibility report is not publicly available.</p>
          ) : errorType === 'no_scan_data' ? (
            <p>This store hasn't completed an accessibility scan yet.</p>
          ) : (
            <p>This report is currently unavailable. Please try again later.</p>
          )}
          <a href="https://getaccessfix.app" class="cta-link">
            Get your own accessibility report
          </a>
        </div>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .report-page {
    max-width: 680px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  .report-container {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .report-header {
    text-align: center;
  }

  .report-label {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent-text);
    margin-bottom: 8px;
  }

  .report-header h1 {
    font-family: 'Outfit', sans-serif;
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.5px;
    margin-bottom: 4px;
  }

  .scan-date {
    color: var(--fg-muted);
    font-size: 0.9rem;
  }

  .score-block {
    text-align: center;
    padding: 32px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .score-number {
    font-family: 'Outfit', sans-serif;
    font-size: 72px;
    font-weight: 800;
    line-height: 1;
  }

  .score-label {
    font-size: 0.95rem;
    color: var(--fg-muted);
    margin-top: 4px;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .stat-card {
    text-align: center;
    padding: 20px 12px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
  }

  .stat-value {
    font-family: 'Outfit', sans-serif;
    font-size: 1.8rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .stat-label {
    font-size: 0.82rem;
    color: var(--fg-muted);
    margin-top: 2px;
  }

  .severity-section h2,
  .info-section h2 {
    font-family: 'Outfit', sans-serif;
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 12px;
  }

  .severity-grid {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .severity-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 16px;
    border-radius: var(--radius-sm);
  }

  .severity-row.critical {
    background: var(--red-bg);
    border: 1px solid var(--red-border);
  }

  .severity-row.serious {
    background: var(--orange-bg);
    border: 1px solid var(--orange-border);
  }

  .severity-row.minor {
    background: var(--surface);
    border: 1px solid var(--border);
  }

  .severity-badge {
    font-size: 0.875rem;
    font-weight: 600;
  }

  .severity-row.critical .severity-badge { color: var(--red); }
  .severity-row.serious .severity-badge { color: var(--orange); }
  .severity-row.minor .severity-badge { color: var(--fg-muted); }

  .severity-count {
    font-family: 'Outfit', sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
  }

  .info-section p {
    color: var(--fg-muted);
    font-size: 0.92rem;
    line-height: 1.7;
  }

  .info-section a {
    color: var(--accent-text);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .info-section ul {
    margin-top: 12px;
    padding-left: 20px;
    color: var(--fg-muted);
    font-size: 0.92rem;
    line-height: 1.8;
  }

  .report-footer {
    text-align: center;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    color: var(--fg-faint);
    font-size: 0.85rem;
  }

  .report-footer a {
    color: var(--accent-text);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .empty-state {
    text-align: center;
    padding: 48px 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .empty-state p {
    color: var(--fg-muted);
    font-size: 1rem;
    margin-bottom: 24px;
  }

  .cta-link {
    display: inline-block;
    padding: 12px 24px;
    background: var(--accent);
    color: #fff;
    font-weight: 600;
    font-size: 0.9rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background 0.2s;
  }

  .cta-link:hover {
    background: var(--accent-hover);
  }

  @media (max-width: 480px) {
    .stats-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
