---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="AccessFix — Find & Fix Accessibility Issues in Your Shopify Store">

  <!-- HERO -->
  <div class="hero">
    <div class="hero-badge">
      <svg aria-hidden="true" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M8 1v6M4.5 3.5L8 7l3.5-3.5M2 11h12M4 14h8"/></svg>
      Accessibility lawsuits up 300% since 2018
    </div>
    <h1>Your Shopify store has accessibility&nbsp;violations. Find and fix&nbsp;them.</h1>
    <p>AccessFix scans your storefront for WCAG 2.1 AA issues and gives you step-by-step instructions to fix them in your Shopify theme. No developer needed.</p>
    <form class="waitlist-form" id="hero-form">
      <input type="email" name="email" placeholder="you@example.com" required aria-label="Email address" />
      <button type="submit" class="hero-cta">
        Join the Waitlist
        <svg aria-hidden="true" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 3l5 5-5 5"/></svg>
      </button>
    </form>
    <p class="hero-sub">Be the first to know when AccessFix launches.</p>
  </div>

  <!-- JURISDICTION STRIP -->
  <div class="jurisdictions">
    <p>Accessibility compliance is now law in</p>
    <div class="jurisdiction-grid">
      <div class="jurisdiction-tag"><span class="flag" aria-hidden="true">🇺🇸</span> ADA — United States</div>
      <div class="jurisdiction-tag"><span class="flag" aria-hidden="true">🇪🇺</span> EAA — European Union</div>
      <div class="jurisdiction-tag"><span class="flag" aria-hidden="true">🇬🇧</span> Equality Act — United Kingdom</div>
      <div class="jurisdiction-tag"><span class="flag" aria-hidden="true">🇨🇦</span> AODA — Canada</div>
      <div class="jurisdiction-tag"><span class="flag" aria-hidden="true">🇦🇺</span> DDA — Australia</div>
    </div>
  </div>

  <!-- RISK -->
  <section aria-labelledby="risk-heading">
    <p class="section-label">The risk</p>
    <h2 id="risk-heading">Ignoring accessibility is expensive</h2>
    <p class="section-desc">Regulations are tightening worldwide. Enforcement is real — and it hits online stores.</p>
    <div class="risk-cards">
      <div class="risk-card">
        <div class="risk-icon red" aria-hidden="true">⚖️</div>
        <h3>Lawsuits are accelerating</h3>
        <p>In the US alone, ADA-related web accessibility lawsuits have surged. Plaintiffs target e-commerce stores specifically because violations are easy to prove.</p>
        <span class="risk-stat red">4,000+ lawsuits filed in 2023</span>
      </div>
      <div class="risk-card">
        <div class="risk-icon orange" aria-hidden="true">💶</div>
        <h3>Fines add up fast</h3>
        <p>The EU's European Accessibility Act is enforceable now. Non-compliant stores selling to European customers face fines set by each member state.</p>
        <span class="risk-stat orange">EAA enforceable since June 2025</span>
      </div>
      <div class="risk-card">
        <div class="risk-icon red" aria-hidden="true">🚫</div>
        <h3>15% of customers can't use your store</h3>
        <p>Over a billion people worldwide have a disability. If your store isn't accessible, you're losing revenue from customers who want to buy but physically can't.</p>
        <span class="risk-stat red">~1.3 billion people affected globally</span>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section aria-labelledby="how-heading">
    <p class="section-label">How it works</p>
    <h2 id="how-heading">Scan, understand, fix</h2>
    <p class="section-desc">AccessFix finds the real issues in your theme code and tells you exactly how to fix them — in plain English.</p>
    <div class="steps">
      <div class="step">
        <span class="step-number">01</span>
        <h3>Install</h3>
        <p>Add AccessFix from the Shopify App Store. Takes 30 seconds. Nothing is added to your storefront — zero impact on store speed.</p>
      </div>
      <div class="step">
        <span class="step-number">02</span>
        <h3>Scan</h3>
        <p>Click "Run Scan." AccessFix checks your homepage, product pages, collections, and more. Up to 20 pages scanned in under 2 minutes.</p>
      </div>
      <div class="step">
        <span class="step-number">03</span>
        <h3>Fix</h3>
        <p>Each issue comes with step-by-step instructions for the Shopify Theme Editor. Exact file paths, plain-English explanations, copy-paste code snippets when needed.</p>
      </div>
    </div>
  </section>

  <!-- WIDGET COMPARISON -->
  <section aria-labelledby="compare-heading">
    <p class="section-label">Widgets vs. real fixes</p>
    <h2 id="compare-heading">Already using an accessibility widget?</h2>
    <p class="section-desc">Overlay widgets add a toolbar to your store. They don't fix your code — and regulators know the difference.</p>
    <div class="compare-grid">
      <div class="compare-card bad">
        <p class="compare-label">Accessibility widgets</p>
        <h3>Surface-level patches</h3>
        <ul role="list">
          <li>Add JavaScript that covers up issues</li>
          <li>Don't change your actual source code</li>
          <li>Courts have ruled these insufficient</li>
          <li>You can still be fined or sued</li>
        </ul>
      </div>
      <div class="compare-card good">
        <p class="compare-label">AccessFix</p>
        <h3>Real fixes in your theme</h3>
        <ul role="list">
          <li>Nothing added to your storefront</li>
          <li>Finds actual issues in your code</li>
          <li>You fix the source — what regulators check</li>
          <li>Your store becomes genuinely accessible</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section aria-labelledby="features-heading">
    <p class="section-label">Why AccessFix</p>
    <h2 id="features-heading">Built for Shopify merchants, not developers</h2>
    <div class="features-grid">
      <div class="feature">
        <h3>Zero impact on store speed</h3>
        <p>Scans run from our servers. No scripts, widgets, or apps on your storefront. Your page speed stays exactly the same.</p>
      </div>
      <div class="feature">
        <h3>Same engine the pros use</h3>
        <p>Powered by axe-core — the open-source engine trusted by Microsoft, Google, and professional accessibility auditors worldwide.</p>
      </div>
      <div class="feature">
        <h3>Theme-specific instructions</h3>
        <p>Fix instructions include exact file paths for Dawn, Horizon, Debut, Refresh, Sense, and more. Instructions adapt to your theme automatically.</p>
      </div>
      <div class="feature">
        <h3>No developer needed</h3>
        <p>Every fix is written for the Shopify Theme Editor. Most issues can be resolved without touching code. When code is needed, you get copy-paste snippets.</p>
      </div>
      <div class="feature">
        <h3>Track your progress</h3>
        <p>See your compliance score improve as you fix issues. Know exactly where you stand and what's left to do.</p>
      </div>
      <div class="feature">
        <h3>Works alongside widgets</h3>
        <p>Keep your widget while you fix the real issues underneath. Once your code is clean, you won't need the widget anymore.</p>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section aria-labelledby="pricing-heading">
    <p class="section-label">Pricing</p>
    <h2 id="pricing-heading">Start with a free scan</h2>
    <p class="section-desc">See every issue in your store for free. Upgrade when you're ready to fix everything.</p>
    <div class="pricing-grid">
      <div class="price-card">
        <h3>Free</h3>
        <div class="price-amount">$0</div>
        <span class="price-period">forever</span>
        <ul class="price-features" role="list">
          <li>Full scan — up to 20 pages</li>
          <li>Every issue listed with severity</li>
          <li>Compliance score</li>
          <li>Fix instructions for 3 issue types</li>
        </ul>
        <a href="#waitlist" class="price-cta outline">Join Waitlist</a>
      </div>
      <div class="price-card featured">
        <h3>Fix</h3>
        <div class="price-amount">$19.99</div>
        <span class="price-period">per month</span>
        <ul class="price-features" role="list">
          <li>Everything in Free</li>
          <li>Fix instructions for ALL issues</li>
          <li>Code snippets with one-click copy</li>
          <li>Theme-specific file paths</li>
        </ul>
        <a href="#waitlist" class="price-cta filled">Join Waitlist</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section aria-labelledby="faq-heading">
    <p class="section-label">Common questions</p>
    <h2 id="faq-heading">FAQ</h2>
    <div class="faq-list">
      <details class="faq-item">
        <summary>Does AccessFix slow down my store?</summary>
        <p class="faq-a">No. AccessFix scans from our servers. Nothing is installed on your storefront and no scripts are added to your pages. Store speed is completely unaffected.</p>
      </details>
      <details class="faq-item">
        <summary>Does it work with my Shopify theme?</summary>
        <p class="faq-a">Yes. AccessFix works with any Shopify theme. Fix instructions include specific file paths for Dawn, Horizon, Debut, Refresh, and Sense. For other themes, instructions are generated to match automatically.</p>
      </details>
      <details class="faq-item">
        <summary>What is WCAG 2.1 AA?</summary>
        <p class="faq-a">WCAG (Web Content Accessibility Guidelines) is the international standard for web accessibility. Level AA is what the ADA, EAA, AODA, and other laws reference. It covers things like image descriptions, text contrast, keyboard navigation, and form labels. AccessFix scans for this level.</p>
      </details>
      <details class="faq-item">
        <summary>I'm not technical. Can I fix the issues myself?</summary>
        <p class="faq-a">Yes. Fix instructions are written in plain English with exact steps for the Shopify Theme Editor. Many issues — like adding alt text — need no code at all. When code is needed, you get exact snippets to copy and paste.</p>
      </details>
      <details class="faq-item">
        <summary>Which laws require this?</summary>
        <p class="faq-a">In the US, the ADA is increasingly applied to websites — over 4,000 lawsuits were filed in 2023. The EU's European Accessibility Act became enforceable in June 2025. Canada's AODA, the UK's Equality Act, and Australia's Disability Discrimination Act all set similar requirements. They all reference WCAG 2.1 AA.</p>
      </details>
      <details class="faq-item">
        <summary>Can I use AccessFix alongside an existing widget?</summary>
        <p class="faq-a">Yes. Many merchants run both while working through fixes. AccessFix addresses the real issues in your theme code. Once your code is clean, the widget becomes unnecessary.</p>
      </details>
    </div>
  </section>

  <!-- BOTTOM CTA / WAITLIST -->
  <section class="bottom-cta" id="waitlist" aria-labelledby="cta-heading">
    <div class="bottom-cta-box">
      <h2 id="cta-heading">Get notified when we launch</h2>
      <p>Join the waitlist. We'll email you when AccessFix is ready.</p>
      <form class="waitlist-form bottom-waitlist-form" id="bottom-form">
        <input type="email" name="email" placeholder="you@example.com" required aria-label="Email address" />
        <button type="submit">
          Join Waitlist
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 3l5 5-5 5"/></svg>
        </button>
      </form>
    </div>
  </section>

</BaseLayout>

<style>
  /* HERO */
  .hero {
    max-width: 720px;
    margin: 60px auto 0;
    padding: 0 24px;
    text-align: center;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    background: var(--red-bg);
    border: 1px solid var(--red-border);
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--red);
    margin-bottom: 24px;
  }
  .hero h1 {
    font-size: clamp(2.2rem, 5vw, 3.2rem);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -0.035em;
    margin-bottom: 20px;
  }
  .hero p {
    font-size: 1.15rem;
    color: var(--fg-muted);
    max-width: 560px;
    margin: 0 auto 32px;
    line-height: 1.65;
  }
  /* WAITLIST FORM */
  .waitlist-form {
    display: flex;
    gap: 8px;
    max-width: 480px;
    margin: 0 auto;
  }
  .waitlist-form input[type="email"] {
    flex: 1;
    padding: 16px 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--fg);
    font-size: 1rem;
    font-family: var(--font);
    min-width: 0;
  }
  .waitlist-form input[type="email"]::placeholder {
    color: var(--fg-faint);
  }
  .waitlist-form input[type="email"]:focus {
    outline: 2px solid var(--accent);
    outline-offset: -1px;
    border-color: var(--accent);
  }
  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 32px;
    background: var(--accent);
    color: #fff;
    text-decoration: none;
    font-size: 1.125rem;
    font-weight: 700;
    border-radius: var(--radius);
    border: none;
    cursor: pointer;
    font-family: var(--font);
    transition: background 0.2s;
    white-space: nowrap;
  }
  .hero-cta:hover { background: var(--accent-hover); }
  .hero-sub {
    margin-top: 12px;
    font-size: 0.85rem;
    color: var(--fg-faint);
  }
  @media (max-width: 500px) {
    .waitlist-form {
      flex-direction: column;
    }
    .hero-cta {
      justify-content: center;
    }
  }

  /* JURISDICTION STRIP */
  .jurisdictions {
    max-width: 720px;
    margin: 56px auto 0;
    padding: 0 24px;
    text-align: center;
  }
  .jurisdictions p {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--fg-faint);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 16px;
  }
  .jurisdiction-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
  }
  .jurisdiction-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--fg);
  }
  .jurisdiction-tag .flag { font-size: 1rem; }

  /* SECTIONS */
  section {
    max-width: 1080px;
    margin: 0 auto;
    padding: 80px 24px 0;
  }
  .section-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent-text);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 12px;
  }
  section > h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: 16px;
  }
  section > .section-desc {
    font-size: 1.05rem;
    color: var(--fg-muted);
    max-width: 600px;
    line-height: 1.6;
    margin-bottom: 40px;
  }

  /* RISK SECTION */
  .risk-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 16px;
  }
  .risk-card {
    padding: 28px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .risk-card .risk-icon {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    margin-bottom: 16px;
  }
  .risk-card .risk-icon.red { background: var(--red-bg); }
  .risk-card .risk-icon.orange { background: var(--orange-bg); }
  .risk-card h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }
  .risk-card p {
    font-size: 0.9rem;
    color: var(--fg-muted);
    line-height: 1.55;
  }
  .risk-stat {
    display: inline-block;
    margin-top: 12px;
    padding: 4px 10px;
    font-family: var(--mono);
    font-size: 0.8rem;
    font-weight: 500;
    border-radius: 6px;
  }
  .risk-stat.red { background: var(--red-bg); color: var(--red); }
  .risk-stat.orange { background: var(--orange-bg); color: var(--orange); }

  /* HOW IT WORKS */
  .steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }
  .step {
    padding: 28px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .step-number {
    font-family: var(--mono);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--accent-text);
    margin-bottom: 14px;
    display: block;
  }
  .step h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }
  .step p {
    font-size: 0.9rem;
    color: var(--fg-muted);
    line-height: 1.55;
  }

  /* WIDGET COMPARISON */
  .compare-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  @media (max-width: 640px) {
    .compare-grid { grid-template-columns: 1fr; }
  }
  .compare-card {
    padding: 28px;
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }
  .compare-card.bad {
    background: var(--red-bg);
    border-color: var(--red-border);
  }
  .compare-card.good {
    background: var(--accent-bg);
    border-color: var(--accent-border);
  }
  .compare-card .compare-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 16px;
  }
  .compare-card.bad .compare-label { color: var(--red); }
  .compare-card.good .compare-label { color: var(--accent-text); }
  .compare-card h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }
  .compare-card ul {
    list-style: none;
    padding: 0;
  }
  .compare-card ul li {
    font-size: 0.9rem;
    color: var(--fg-muted);
    padding: 6px 0;
    padding-left: 22px;
    position: relative;
    line-height: 1.5;
  }
  .compare-card.bad ul li::before {
    content: "\2717";
    position: absolute;
    left: 0;
    color: var(--red);
    font-weight: 700;
    font-size: 0.8rem;
  }
  .compare-card.good ul li::before {
    content: "\2713";
    position: absolute;
    left: 0;
    color: var(--accent-text);
    font-weight: 700;
    font-size: 0.85rem;
  }

  /* FEATURES */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 16px;
  }
  .feature {
    padding: 28px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .feature h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }
  .feature p {
    font-size: 0.9rem;
    color: var(--fg-muted);
    line-height: 1.55;
  }

  /* PRICING */
  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    max-width: 680px;
  }
  @media (max-width: 640px) {
    .pricing-grid { grid-template-columns: 1fr; }
  }
  .price-card {
    padding: 32px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .price-card.featured {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent);
  }
  .price-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 4px;
  }
  .price-amount {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 8px 0 4px;
  }
  .price-period {
    font-size: 0.85rem;
    color: var(--fg-faint);
    margin-bottom: 20px;
    display: block;
  }
  .price-features {
    list-style: none;
    padding: 0;
    margin-bottom: 24px;
  }
  .price-features li {
    font-size: 0.875rem;
    color: var(--fg-muted);
    padding: 5px 0;
    padding-left: 20px;
    position: relative;
    line-height: 1.5;
  }
  .price-features li::before {
    content: "\2713";
    position: absolute;
    left: 0;
    color: var(--accent-text);
    font-weight: 700;
    font-size: 0.8rem;
  }
  .price-cta {
    display: block;
    width: 100%;
    padding: 12px;
    text-align: center;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    border-radius: var(--radius-sm);
    transition: all 0.2s;
  }
  .price-cta.outline {
    background: transparent;
    color: var(--fg);
    border: 1px solid var(--border);
  }
  .price-cta.outline:hover { border-color: var(--fg-faint); }
  .price-cta.filled {
    background: var(--accent);
    color: #fff;
    border: 1px solid var(--accent);
    font-size: 1rem;
    font-weight: 700;
  }
  .price-cta.filled:hover { background: var(--accent-hover); }

  /* FAQ */
  .faq-list {
    max-width: 680px;
  }
  .faq-item {
    border-bottom: 1px solid var(--border);
  }
  .faq-item:first-child {
    border-top: 1px solid var(--border);
  }
  .faq-item summary {
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    letter-spacing: -0.01em;
    padding: 20px 0;
    list-style: none;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after {
    content: "+";
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--fg-faint);
    transition: transform 0.2s;
    flex-shrink: 0;
  }
  .faq-item[open] summary::after {
    transform: rotate(45deg);
  }
  .faq-a {
    font-size: 0.9rem;
    color: var(--fg-muted);
    line-height: 1.6;
    padding-bottom: 20px;
  }

  /* BOTTOM CTA */
  .bottom-cta {
    max-width: 1080px;
    margin: 80px auto 0;
    padding: 0 24px 80px;
    text-align: center;
  }
  .bottom-cta-box {
    padding: 56px 40px;
    background: var(--cta-box-bg);
    border: 1px solid var(--cta-box-border);
    border-radius: 16px;
    color: var(--cta-box-fg);
  }
  .bottom-cta-box h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 12px;
  }
  .bottom-cta-box p {
    color: var(--cta-box-muted);
    font-size: 1rem;
    margin-bottom: 28px;
  }
  .bottom-waitlist-form {
    max-width: 460px;
    margin: 0 auto;
  }
  .bottom-waitlist-form input[type="email"] {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.15);
    color: #fff;
  }
  .bottom-waitlist-form input[type="email"]::placeholder {
    color: rgba(255, 255, 255, 0.4);
  }
  .bottom-waitlist-form button {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 28px;
    background: var(--accent);
    color: #fff;
    font-size: 1rem;
    font-weight: 700;
    border: none;
    border-radius: var(--radius);
    cursor: pointer;
    font-family: var(--font);
    transition: background 0.2s;
    white-space: nowrap;
  }
  .bottom-waitlist-form button:hover { background: var(--accent-hover); }
  .waitlist-success {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent-text);
    padding: 16px 0;
  }
  .bottom-waitlist-form .waitlist-success {
    color: #2dd4bf;
  }
</style>

<script>
  document.querySelectorAll('.waitlist-form').forEach(form => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const emailInput = form.querySelector('input[type="email"]');
      const email = emailInput.value;
      const btn = form.querySelector('button');
      const originalHTML = btn.innerHTML;
      btn.disabled = true;
      btn.textContent = 'Joining...';

      try {
        const res = await fetch('https://formsubmit.co/ajax/support@getaccessfix.app', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ email, _subject: 'New AccessFix Waitlist Signup' })
        });
        if (!res.ok) throw new Error('Failed');
        form.innerHTML = '<p class="waitlist-success">You\'re on the list! We\'ll be in touch.</p>';
      } catch {
        btn.disabled = false;
        btn.innerHTML = originalHTML;
        window.location.href = 'mailto:support@getaccessfix.app?subject=AccessFix%20Waitlist&body=Please%20add%20me%20to%20the%20waitlist.%20My%20email%3A%20' + encodeURIComponent(email);
      }
    });
  });
</script>
