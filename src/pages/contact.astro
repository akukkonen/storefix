---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — AccessFix" description="Get in touch with AccessFix. We respond within 24 hours.">
  <div class="contact-page">
    <h1>Contact</h1>
    <p>Have a question, need help, or want to report an issue? Reach out and we'll get back to you within 24 hours.</p>
    <a href="mailto:arttukoo@gmail.com" class="contact-email">arttukoo@gmail.com</a>
    <p class="contact-note">You can also check the <a href="/support">Support page</a> for setup guides and answers to common questions.</p>
  </div>
</BaseLayout>

<style>
  .contact-page {
    max-width: 520px;
    margin: 0 auto;
    padding: 80px 24px 120px;
    text-align: center;
  }
  .contact-page h1 {
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
  }
  .contact-page > p {
    font-size: 1.05rem;
    color: var(--fg-muted);
    line-height: 1.6;
    margin-bottom: 28px;
  }
  .contact-email {
    display: inline-block;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: underline;
    margin-bottom: 32px;
  }
  .contact-email:hover { color: var(--accent-hover); }
  .contact-note {
    font-size: 0.9rem;
    color: var(--fg-faint);
  }
  .contact-note a {
    color: var(--fg-muted);
    text-decoration: underline;
  }
  .contact-note a:hover { color: var(--fg); }
</style>
